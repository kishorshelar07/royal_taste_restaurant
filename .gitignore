# ═══════════════════════════════════════
# NODE MODULES — Never push
# ═══════════════════════════════════════
node_modules/
*/node_modules/
**/node_modules/
frontend/node_modules/
backend/node_modules/

# ═══════════════════════════════════════
# ENVIRONMENT FILES — Never push (passwords ahet)
# ═══════════════════════════════════════
.env
.env.local
.env.development
.env.production
.env.test
**/.env
*/.env
backend/.env
frontend/.env

# ═══════════════════════════════════════
# BUILD FILES
# ═══════════════════════════════════════
frontend/build/
frontend/.cache/
build/
dist/

# ═══════════════════════════════════════
# UPLOADS (user uploaded images)
# ═══════════════════════════════════════
backend/uploads/*
!backend/uploads/.gitkeep

# ═══════════════════════════════════════
# LOGS
# ═══════════════════════════════════════
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ═══════════════════════════════════════
# OS FILES
# ═══════════════════════════════════════
.DS_Store
.DS_Store?
Thumbs.db
